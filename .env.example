# ─────────────────────────────────────────────────────────────────
# WP Blog Pipeline — environment variables
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────────

# ── WordPress (used by wp-publisher) ─────────────────────────────
WP_BASE_URL=https://your-site.com
WP_API_BASE=https://your-site.com/wp-json/wp/v2
WP_USER=your-editor-username
# Generate at: wp-admin → Users → Profile → Application Passwords
# Copy the 24-char string here. Spaces are OK; WP accepts with or without.
WP_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx
# Numeric user ID of the default author for agent-published posts.
# Find via: curl -s -u "user:pass" https://your-site.com/wp-json/wp/v2/users/me | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])"
WP_DEFAULT_AUTHOR_ID=1

# ── Search engine indexing (optional, used by wp-publisher on --live) ──
# Install the IndexNow plugin in WP admin, copy the key it generates here.
# Also host the key file at https://your-site.com/<key>.txt (the plugin does this).
INDEXNOW_KEY=

# ── Google Search Console URL Inspection API (optional, advanced) ──
# Requires a service account with Search Console access.
# Path to the service account JSON key file.
GSC_SERVICE_ACCOUNT_JSON=